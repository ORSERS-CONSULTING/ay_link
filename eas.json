{
  "cli": {
    "version": ">= 16.3.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_SECRET": "$API_SECRET",
        "CLIENT_ID": "$CLIENT_ID",
        "CLIENT_SECRET": "$CLIENT_SECRET",
        "ACCESS_TOKEN_URL": "$ACCESS_TOKEN_URL",
        "BASE_SCOPE_URL": "$BASE_SCOPE_URL",
        "BACKEND_URL": "$BACKEND_URL"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "API_SECRET": "$API_SECRET",
        "CLIENT_ID": "$CLIENT_ID",
        "CLIENT_SECRET": "$CLIENT_SECRET",
        "ACCESS_TOKEN_URL": "$ACCESS_TOKEN_URL",
        "BASE_SCOPE_URL": "$BASE_SCOPE_URL",
        "BACKEND_URL": "$BACKEND_URL"
      }
    },
    "production": {
      "autoIncrement": true,
  "env": {
  "API_SECRET": "$API_SECRET",
  "CLIENT_ID": "$CLIENT_ID",
  "CLIENT_SECRET": "$CLIENT_SECRET",
  "ACCESS_TOKEN_URL": "$ACCESS_TOKEN_URL",
  "BASE_SCOPE_URL": "$BASE_SCOPE_URL",
  "BACKEND_URL": "$BACKEND_URL"
}

    }
  },
  "submit": {
    "production": {}
  }
}
